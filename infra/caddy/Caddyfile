{
  admin off
  auto_https disable_redirects
  default_sni {$PANEL_HOST}
  skip_install_trust
}

{$PANEL_HOST}:8443 {
  tls internal
  encode zstd gzip
  root * /srv/web

  basic_auth {
    {$PANEL_BASIC_AUTH_USER} {$PANEL_BASIC_AUTH_PASSWORD_HASH}
  }

  @api path /api/* /healthz /readyz
  reverse_proxy @api api:3000

  header {
    Strict-Transport-Security "max-age=31536000; includeSubDomains"
    X-Content-Type-Options "nosniff"
    X-Frame-Options "DENY"
    Referrer-Policy "no-referrer"
    Permissions-Policy "camera=(), geolocation=(), microphone=()"
    Content-Security-Policy "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; font-src 'self'; script-src 'self'; connect-src 'self'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'"
  }

  try_files {path} /index.html
  file_server
}
