COMPOSE_PROJECT_NAME=xray-vpn-control-plane
NODE_ENV=production

API_PORT=3000
API_LOG_LEVEL=info
API_CORS_ORIGIN=https://panel.example.com:8443
SESSION_COOKIE_NAME=svpn_admin
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=30d
BCRYPT_ROUNDS=12
LOGIN_RATE_LIMIT_TTL_MS=60000
LOGIN_RATE_LIMIT_MAX=10
API_LOG_FILE=/var/log/server-vpn/api.log

PANEL_TLS_MODE=ip
PANEL_HOST=panel.example.com
PANEL_PUBLIC_URL=https://panel.example.com:8443
PANEL_HTTPS_PORT=8443
SERVER_PUBLIC_IP=
# Use PANEL_TLS_MODE=domain with a real DNS name for public TLS on 443.

POSTGRES_DB=server_vpn
POSTGRES_USER=server_vpn
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql://server_vpn:change-me@postgres:5432/server_vpn?schema=public
DATABASE_DIRECT_URL=postgresql://server_vpn:change-me@postgres:5432/server_vpn?schema=public

JWT_ACCESS_SECRET=replace-with-long-random-string
JWT_REFRESH_SECRET=replace-with-another-long-random-string
TOTP_ENCRYPTION_SECRET=replace-with-third-long-random-string
# install.sh auto-fills these on first install unless you override them explicitly.
INITIAL_ADMIN_EMAIL=admin@vpn.local
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=replace-me

XRAY_IMAGE=ghcr.io/xtls/xray-core:26.2.6
XRAY_VLESS_PORT=443
XRAY_VLESS_LISTEN=0.0.0.0
XRAY_INBOUND_TAG=vless-reality-main
XRAY_API_LISTEN=0.0.0.0:10085
XRAY_API_TARGET=xray:10085
XRAY_REALITY_DEST=www.cloudflare.com:443
XRAY_REALITY_SERVER_NAMES=www.cloudflare.com,cdn.cloudflare.com
XRAY_REALITY_PRIVATE_KEY=replace-with-private-key
XRAY_REALITY_PUBLIC_KEY=replace-with-public-key
# One or more 16-character hex short IDs separated by commas.
XRAY_SHORT_IDS=0123456789abcdef
XRAY_DEFAULT_SNI=www.cloudflare.com
XRAY_DEFAULT_SPIDER_X=/
XRAY_PUBLIC_HOST=panel.example.com
XRAY_SUBSCRIPTION_BASE_URL=https://panel.example.com:8443
XRAY_ACCESS_LOG_FILE=/var/log/server-vpn/xray-access.log
XRAY_ERROR_LOG_FILE=/var/log/server-vpn/xray-error.log
XRAY_USAGE_SNAPSHOT_INTERVAL_MS=60000
XRAY_CONTROL_SYNC_INTERVAL_MS=60000

WIREGUARD_ENABLED=false
WIREGUARD_INTERFACE=wg0
WIREGUARD_PORT=51820
WIREGUARD_SERVER_PRIVATE_KEY=
WIREGUARD_SERVER_PUBLIC_KEY=
WIREGUARD_SERVER_ADDRESS_CIDR=10.44.0.1/24
WIREGUARD_PUBLIC_HOST=
WIREGUARD_ALLOWED_IPS=0.0.0.0/0,::/0
WIREGUARD_CLIENT_DNS=1.1.1.1,1.0.0.1
WIREGUARD_PERSISTENT_KEEPALIVE=25
WIREGUARD_MTU=1420
WIREGUARD_CONFIG_ENCRYPTION_SECRET=
WIREGUARD_CONFIG_PATH=/var/lib/server-vpn/wireguard/generated/wg0.conf
WIREGUARD_RUNTIME_DUMP_PATH=/var/lib/server-vpn/wireguard/runtime/wg-show.dump
WIREGUARD_RUNTIME_SYNC_INTERVAL_MS=60000
WIREGUARD_EGRESS_INTERFACE=eth0
WIREGUARD_AUTO_ENABLE_LEGACY_CLIENTS=true
WIREGUARD_LOG_FILE=/var/log/server-vpn/wireguard.log

BACKUP_DIR=/var/backups/server-vpn
# Leave empty on first install; deploy.sh will normalize this to <repo>/infra/backup/output.
BACKUP_HOST_DIR=
BACKUP_AUTO_CREATE_ENABLED=true
BACKUP_AUTO_CREATE_INTERVAL_DAYS=5
BACKUP_AUTO_MAINTENANCE_INTERVAL_MS=3600000
BACKUP_RETENTION_DAYS=14
CADDY_ACCESS_LOG_FILE=/var/log/server-vpn/caddy-access.log
